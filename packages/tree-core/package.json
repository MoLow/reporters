{
  "name": "@reporters/tree-core",
  "version": "0.0.0",
  "description": "Shared tree-state model for @reporters/live and @reporters/web",
  "type": "module",
  "private": true,
  "keywords": [
    "node:test",
    "test",
    "reporter",
    "reporters",
    "tree"
  ],
  "files": [
    "./dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "test": "node --test-reporter=../gh/index.js --test"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.7.0"
  },
  "bugs": {
    "url": "https://github.com/MoLow/reporters/issues"
  },
  "homepage": "https://github.com/MoLow/reporters/tree/main/packages/tree-core",
  "repository": "https://github.com/MoLow/reporters.git",
  "author": "Moshe Atlow",
  "license": "MIT"
}
